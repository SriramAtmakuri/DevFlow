GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
BRAVE_API_KEY=your_brave_search_api_key_here
JWT_SECRET_KEY=change-this-to-a-strong-random-secret

# Database — defaults to SQLite for local dev; set to PostgreSQL for production
DATABASE_URL=postgresql://devflow:yourpassword@localhost:5432/devflow

# Redis
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# Storage
CHROMA_PATH=./chroma_db

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# Services
GO_SCRAPER_URL=http://localhost:8001

# Observability (optional — remove if not using)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
ENVIRONMENT=production

# S3 file storage (optional — leave blank to keep in-memory processing)
AWS_S3_BUCKET=your-s3-bucket-name
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
